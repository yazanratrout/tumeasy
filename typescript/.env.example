# =============================================================================
# AWS Credentials
# Copy temporary credentials from the SSO portal, or use long-lived keys.
# ⚠️  NEVER commit this file to git! It is already in .gitignore.
# =============================================================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1

# =============================================================================
# Bedrock Models — INFERENCE PROFILE IDs (required!)
#
# See: https://docs.aws.amazon.com/bedrock/latest/userguide/inference-profiles-support.html
# Use "eu.", or "global." if eu not available.
# =============================================================================

BEDROCK_CHAT_MODEL=eu.amazon.nova-pro-v1:0
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# =============================================================================
# S3 — Change to your team's bucket name
# =============================================================================

S3_BUCKET=hackathon-team-xx-data

# =============================================================================
# S3 Vectors — Change to your team's vector bucket/index
# =============================================================================

S3_VECTOR_BUCKET=hackathon-team-xx-vectors
S3_VECTOR_INDEX=knowledge-base
S3_VECTOR_DIMENSIONS=1024